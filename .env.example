# Copy to .env and fill in your values. .env is gitignored.

# Google Cloud — BigQuery Sandbox
GCP_PROJECT_ID=olist-portfolio
BQ_LOCATION=US
BQ_DATASET_RAW=ecom_raw
BQ_DATASET_STAGING=ecom_staging
BQ_DATASET_MARTS=ecom_marts
BQ_DATASET_ML=ecom_ml

# Kaggle (CLI reads ~/.kaggle/kaggle.json by default, override only if needed)
KAGGLE_DATASET=olistbr/brazilian-ecommerce

# dbt
DBT_PROFILES_DIR=./dbt/olist_warehouse
DBT_TARGET=dev
